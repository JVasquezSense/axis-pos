# Activa el backend real en lugar de los mocks (true/false)
NEXT_PUBLIC_USE_API=false
# URL del backend Django REST Framework (cuando se reemplacen los mocks)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# URL del WebSocket de Django Channels (cocina / pedidos en tiempo real)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Axis IA — GLM-4.5 (Zhipu / Z.ai). SOLO servidor, NO usar NEXT_PUBLIC.
GLM_API_KEY=
GLM_MODEL=glm-4.5-air
# BigModel (China): https://open.bigmodel.cn/api/paas/v4 · Z.ai (intl): https://api.z.ai/api/paas/v4
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
