# ─── Frontend ───────────────────────────────────────────────────────────────
# true  → llama al backend real (Django REST Framework en Railway)
# false → modo demo con datos mock (default para desarrollo local)
NEXT_PUBLIC_USE_API=false

# URL base de la API (sin trailing slash en /api/v1)
# Local:    http://localhost:8000/api/v1
# Railway:  https://<tu-app>.up.railway.app/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WebSocket de Django Channels (KDS en tiempo real — Fase B)
# Local:    ws://localhost:8000
# Railway:  wss://<tu-app>.up.railway.app
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── Axis IA ─────────────────────────────────────────────────────────────────
# SOLO servidor (sin prefijo NEXT_PUBLIC_). Nunca exponer en el cliente.
GLM_API_KEY=
GLM_MODEL=glm-4.5-flash
# BigModel (China): https://open.bigmodel.cn/api/paas/v4
# Z.ai (internacional): https://api.z.ai/api/paas/v4
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
